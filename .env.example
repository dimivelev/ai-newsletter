# Copy this to `.env` and fill in the key for whichever provider you chose
# in config.yaml. You don't need both — just the one matching `provider:`.

# Anthropic (Claude) — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# NVIDIA NIM — get a key at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...
